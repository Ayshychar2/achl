generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int               @id @default(autoincrement())
  email           String            @unique
  password        String
  name            String?
  role            String            @default("STUDENT") // STUDENT, COMPANY, ADMIN, HR
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  enrollments     Enrollment[]
  studentProgress StudentProgress[]
  hiringReqs      HiringRequirement[]
  referredIn      ReferredStudent[]
}

model DemoRequest {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  createdAt DateTime @default(now())
}

model Course {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  sessions    Session[]
  enrollments Enrollment[]
}

model Session {
  id          Int               @id @default(autoincrement())
  courseId    Int
  course      Course            @relation(fields: [courseId], references: [id])
  title       String
  order       Int               // 1 to 8
  progresses  StudentProgress[]
}

model Enrollment {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  courseId    Int
  course      Course   @relation(fields: [courseId], references: [id])
  enrolledAt  DateTime @default(now())

  @@unique([userId, courseId])
}

model StudentProgress {
  id          Int       @id @default(autoincrement())
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  sessionId   Int
  session     Session   @relation(fields: [sessionId], references: [id])
  completed   Boolean   @default(false)
  completedAt DateTime?
  meetLink    String?

  @@unique([userId, sessionId])
}

model HiringRequirement {
  id          Int      @id @default(autoincrement())
  hrId        Int
  hr          User     @relation(fields: [hrId], references: [id])
  title       String
  description String
  status      String   @default("OPEN")
  createdAt   DateTime @default(now())
  referrals   ReferredStudent[]
}

model ReferredStudent {
  id                  Int               @id @default(autoincrement())
  hiringRequirementId Int
  hiringRequirement   HiringRequirement @relation(fields: [hiringRequirementId], references: [id])
  studentId           Int
  student             User              @relation(fields: [studentId], references: [id])
  status              String            @default("PENDING")
  createdAt           DateTime          @default(now())
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  firstName String
  lastName  String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())
}
